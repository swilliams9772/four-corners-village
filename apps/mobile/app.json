{
  "expo": {
    "name": "Four Corners Village",
    "slug": "four-corners",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fourcorners",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B0B12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "village.fourcorners.app",
      "associatedDomains": [
        "applinks:fourcorners.village",
        "applinks:www.fourcorners.village"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Optional — used only if you choose to upload a profile photo.",
        "NSPhotoLibraryUsageDescription": "Optional — used only if you choose to set a profile photo.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B12"
      },
      "package": "village.fourcorners.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "https", "host": "fourcorners.village", "pathPrefix": "/v" },
            { "scheme": "https", "host": "fourcorners.village", "pathPrefix": "/tv" }
          ],
          "category": ["BROWSABLE", "DEFAULT"],
          "autoVerify": true
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-screen-capture",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#9D7EFF"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/fraunces/Fraunces_400Regular.ttf",
            "node_modules/@expo-google-fonts/fraunces/Fraunces_500Medium.ttf",
            "node_modules/@expo-google-fonts/fraunces/Fraunces_600SemiBold.ttf",
            "node_modules/@expo-google-fonts/geist/Geist_400Regular.ttf",
            "node_modules/@expo-google-fonts/geist/Geist_500Medium.ttf",
            "node_modules/@expo-google-fonts/geist/Geist_600SemiBold.ttf"
          ]
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": "https://fourcorners.village"
      },
      "eas": {
        "projectId": "TBD-RUN-EAS-INIT"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
