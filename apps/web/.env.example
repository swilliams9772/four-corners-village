# ============================================================
# 4 Corners Village — environment variables
# Copy to .env.local and fill in. Anything left blank disables
# that integration and falls back to dev/mock mode.
#
# See docs/launch.md for step-by-step provisioning instructions
# for every service below.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="4 Corners Village"

# --- Supabase (auth + Postgres + storage + realtime) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (subscriptions + Connect 85/15) ---
# Live mode keys for prod, test mode keys for preview/dev
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (create in dashboard, see docs/launch.md)
STRIPE_PRICE_TV_MONTHLY=         # $5.55/mo Vintage TV
STRIPE_PRICE_TV_ANNUAL=          # $55.55/yr Vintage TV
STRIPE_PRICE_INITIATE=           # $49/mo practitioner
STRIPE_PRICE_GUIDE=              # $149/mo practitioner
STRIPE_PRICE_SANCTUARY=          # $399/mo practitioner

# --- Cloudflare Stream (Vintage TV video) ---
# Account ID — Cloudflare dashboard sidebar
CLOUDFLARE_ACCOUNT_ID=
# Token with Stream:Edit scope — My Profile → API Tokens
CLOUDFLARE_STREAM_API_TOKEN=
# Customer subdomain from Stream dashboard, e.g. customer-abc123
CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Signing key from Stream → Keys → Create
# JWK is the entire `jwk` field as a *single-line* JSON string
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_JWK=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="4 Corners Village <hello@4cornersvillage.com>"

# --- Zoom (Sanctuary tier) ---
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=

# --- AI Oracle ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Sentry ---
# Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- PostHog (analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Admin allowlist (comma-separated emails) ---
ADMIN_EMAILS=

# --- Soft launch / waitlist gate ---
# Set to "1" to require an active waitlist invite before signup
NEXT_PUBLIC_WAITLIST_ONLY=0
