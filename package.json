{
  "name": "four-corners",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@four-corners/web",
    "dev:mobile": "turbo run dev --filter=@four-corners/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "~5.9.3",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase",
      "esbuild",
      "@sentry/cli",
      "sharp",
      "unrs-resolver"
    ]
  }
}
