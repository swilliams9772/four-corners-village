{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".expo/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "EXPO_PUBLIC_*",
        "SUPABASE_SERVICE_ROLE_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRICE_TV_MONTHLY",
        "STRIPE_PRICE_TV_ANNUAL",
        "STRIPE_PRICE_INITIATE",
        "STRIPE_PRICE_GUIDE",
        "STRIPE_PRICE_SANCTUARY",
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_STREAM_API_TOKEN",
        "CLOUDFLARE_STREAM_SIGNING_KEY_ID",
        "CLOUDFLARE_STREAM_SIGNING_JWK",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "ZOOM_CLIENT_ID",
        "ZOOM_CLIENT_SECRET",
        "ZOOM_REDIRECT_URI",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN",
        "ADMIN_EMAILS",
        "NODE_ENV",
        "VERCEL_ENV",
        "VERCEL_URL"
      ]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  },
  "globalDependencies": ["**/.env", "**/.env.local"],
  "globalEnv": ["NODE_ENV"]
}
